# ════════════════════════════════════════════════════════════════════════════
#  Whisper Dictation — Configuration
#
#  HOW TO USE:
#    1. Copy this file:  cp .env.example .env
#    2. Edit .env with your preferences
#    3. Run the app:     python app.py
#
#  Your .env file is git-ignored — changes stay local and private.
#  This file (.env.example) is committed and shared as a reference template.
# ════════════════════════════════════════════════════════════════════════════


# ── Whisper Model ─────────────────────────────────────────────────────────────
#
# Controls the accuracy vs speed tradeoff for speech recognition:
#
#   tiny     ~75MB    Fastest, lowest accuracy. Good for quick short notes.
#   base     ~150MB   Fast, decent accuracy. Works well for clear speech.
#   small    ~500MB   Balanced. Recommended default for most users.
#   medium   ~1.5GB   Slower, high accuracy. Good for accented speech or noise.
#   large-v3 ~3GB     Slowest, best accuracy. Requires ~4GB of free RAM.
#
MODEL_SIZE=small

# Computation backend:
#   int8    — fastest on CPU (recommended for most users)
#   float16 — better for GPU (requires CUDA or ROCm)
#   float32 — slower fallback if int8 causes accuracy issues
COMPUTE_TYPE=int8

# Transcription language.
# Use a two-letter code ("en", "fr", "de", "es", etc.) for best accuracy and speed.
# Leave empty to let Whisper auto-detect the language (slightly slower).
WHISPER_LANGUAGE=en

# Audio capture settings.
# Whisper requires 16000 Hz mono — do not change these unless you know what you're doing.
SAMPLE_RATE=16000
CHANNELS=1

# Auto-stop recording after this many seconds to prevent unbounded memory use.
# 300 = 5 minutes. Lower this if you only do short dictations.
MAX_RECORDING_SECONDS=300

# Hotkey debounce delay in seconds. Prevents double-firing if the key is
# held or released slowly. Increase if you get duplicate triggers.
DEBOUNCE_SECONDS=0.5


# ── Paste Behaviour ───────────────────────────────────────────────────────────
#
# Milliseconds to wait between copying text to the clipboard and simulating Ctrl+V.
# Increase this value if text sometimes pastes as empty (some apps are slower to
# receive clipboard updates).
PASTE_DELAY_MS=100


# ── Notifications ─────────────────────────────────────────────────────────────
#
# Toggle individual desktop notifications on/off.
# All default to true — set to false to silence a specific event.

# Show notification when the app is ready on startup
NOTIFY_ON_READY=true
# Show notification when recording starts ("Speak now...")
NOTIFY_ON_RECORDING=true
# Show notification when recording stops and transcription begins
NOTIFY_ON_TRANSCRIBING=true
# Show notification when transcription (and optional LLM formatting) completes
NOTIFY_ON_DONE=true
# Show notification when a recording is skipped (too short or no speech detected)
NOTIFY_ON_SKIPPED=true

# Controls how much detail error notifications show.
# true  — show full error message in the notification (useful for debugging)
# false — show a clean one-liner; full error is always printed to the terminal
NOTIFY_VERBOSE=false


# ── LLM Formatting — LM Studio ────────────────────────────────────────────────
#
# After Whisper transcribes your speech, the text can be sent to a local LLM for
# cleanup: removing filler words, fixing false starts, correcting punctuation.
#
# REQUIREMENTS:
#   - Download LM Studio: https://lmstudio.ai
#   - Load any chat model (Llama 3.1 8B or similar works well)
#   - Enable "Start Local Server" in LM Studio (default port: 1234)
#
# If LM Studio is not running, the app falls back to raw Whisper output silently.

# Set to false to skip LLM entirely and paste raw Whisper output.
LLM_ENABLED=true

# LM Studio local server base URL. Change the port if you configured a different one.
LLM_BASE_URL=http://localhost:1234/v1

# Model identifier. LM Studio ignores this and uses whichever model is loaded in the UI.
# The field must be non-empty (required by the OpenAI API spec), but the value doesn't matter.
LLM_MODEL=local-model

# How many seconds to wait for the LLM before giving up and pasting the raw transcription.
# Keep this low — a slow or crashed LM Studio should not freeze your dictation flow.
LLM_TIMEOUT=10

# LLM processing mode. Controls what the LLM does with your transcription:
#
#   format     — Removes filler words ("um", "uh", "like"), fixes false starts and
#                mid-sentence corrections, corrects punctuation and capitalization.
#                Does NOT rephrase or shorten. Best for dictating emails, messages,
#                code comments, or any text where exact meaning matters.
#
#   summarize  — Condenses the transcription into a shorter summary of the key points.
#                Best for long voice notes, meeting recaps, or brainstorming dumps
#                where you want a clean distillation rather than the full text.
#
LLM_MODE=format
